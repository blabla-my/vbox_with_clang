diff --git a/kBuild/tools/CLANG.kmk b/kBuild/tools/CLANG.kmk
new file mode 100644
index 00000000..3568e722
--- /dev/null
+++ b/kBuild/tools/CLANG.kmk
@@ -0,0 +1,373 @@
+# $Id: CLANG.kmk 3567 2022-06-26 20:00:02Z bird $
+## @file
+# kBuild Tool Config - Generic 64-bit Clang using the system Clang, for building C++ code.
+#
+
+#
+# Copyright (c) 2004-2017 knut st. osmundsen <bird-kBuild-spam-xviiv@anduin.net>
+#
+# This file is part of kBuild.
+#
